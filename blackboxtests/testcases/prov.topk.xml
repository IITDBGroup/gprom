<entry key="q2.query">
PROVENANCE OF (SELECT sum(b) AS x, a FROM r GROUP BY a ORDER BY x DESC, a LIMIT 1);
</entry>
<entry key="q2.result">
 x | a | prov_r_a | prov_r_b |
------------------------------
 4 | 2 | 2        | 1        |
 4 | 2 | 2        | 3        |
</entry>


