<entry key="q2.query">
PROVENANCE OF (
  WITH x AS (SELECT a, a AS e FROM r),
       y AS (SELECT ra.e, rb.e AS f FROM x ra, x rb WHERE ra.e = rb.e)
  SELECT y.f, x.a
  FROM y, x
  WHERE x.a = y.e
);
</entry>
