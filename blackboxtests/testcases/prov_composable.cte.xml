<entry key="q3.query">
PROVENANCE OF (
WITH x AS (SELECT sum(b) AS mb, a FROM r GROUP BY a),
     maxx AS (SELECT max(mb) AS maxmb FROM x)
SELECT *
FROM x,
     maxx
     WHERE x.mb = maxx.maxmb
);
</entry>
