<entry key="q8.query">
SEQUENCED TEMPORAL (SELECT count(1) AS X FROM TEMP_EMP WITH TIME (FROM_DATE, TO_DATE));
</entry>
<entry key="q8.result">
 x | t_b        | t_e        |
------------------------------
 0 | 1900-01-01 | 1988-09-05 |
 0 | 1995-09-04 | 1998-04-11 |
 0 | 1999-10-31 | 9999-01-01 |
 1 | 1988-09-05 | 1995-09-04 |
 1 | 1998-04-11 | 1999-10-31 |
</entry>

<entry key="q9.query">
SELECT * FROM (SEQUENCED TEMPORAL (SELECT max(1) AS m FROM TEMP_EMP WITH TIME (FROM_DATE, TO_DATE))) sub ORDER BY T_B, T_E;
</entry>
<entry key="q9.result">
 M | T_B        | T_E        |
------------------------------
NULL | 1900-01-01 | 1988-09-05 |
 1           | 1988-09-05 | 1995-09-04 |
 NULL      | 1995-09-04 | 1998-04-11 |
 1           | 1998-04-11 | 1999-10-31 |
 NULL      | 1999-10-31 | 9999-01-01 |
</entry>

<entry key="q10.query">
SEQUENCED TEMPORAL (SELECT DISTINCT A FROM TEMP_TEST WITH TIME(T_BEGIN, T_END));
</entry>
<entry key="q10.result">
 A | T_B | T_E |
----------------
 1 | 1   | 13  |
 2 | 1   | 4   |
</entry>

<entry key="q11.query">
SELECT * FROM (SEQUENCED TEMPORAL (SELECT max(1) AS x,empid FROM TEMP_EMP WITH TIME (FROM_DATE, TO_DATE) GROUP BY empid)) sub ORDER BY empid, T_B, T_E;
</entry>
<entry key="q11.result">
 x      | empid | t_b        | t_e        |
-------------------------------------------
 1      | 10034 | 1998-04-11 | 1999-10-31 |
 1      | 10035 | 1988-09-05 | 1995-09-04 |
</entry>


