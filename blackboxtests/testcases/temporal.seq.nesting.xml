<entry key="q1.query">
SEQUENCED TEMPORAL (
  SELECT r.*
  FROM TEMP_TEST WITH TIME(T_BEGIN, T_END) r
  WHERE A = 2
        AND EXISTS (SELECT *
                    FROM TEMP_TEST WITH TIME(T_BEGIN, T_END) s)
);
</entry>
<entry key="q1.result">
 a | b | t_b | t_e |
--------------------
 2 | 1 | 1   | 2   |
 2 | 1 | 2   | 3   |
 2 | 1 | 3   | 4   |
</entry>

<entry key="q2.query">
SEQUENCED TEMPORAL (
  SELECT r.*
  FROM TEMP_TEST WITH TIME(T_BEGIN, T_END) r
  WHERE A = 2
        AND EXISTS (SELECT *
                    FROM TEMP_TEST WITH TIME(T_BEGIN, T_END) s
                    WHERE r.a = s.b)
);
</entry>
<entry key="q2.result">
 a | b | t_b | t_e |
--------------------
 2 | 1 | 1   | 2   |
 2 | 1 | 2   | 3   |
 2 | 1 | 3   | 4   |
</entry>

<entry key="q3.query">
SEQUENCED TEMPORAL (
  SELECT r.*
  FROM TEMP_TEST WITH TIME(T_BEGIN, T_END) r
  WHERE A = 2
        AND EXISTS (SELECT *
                    FROM TEMP_TEST WITH TIME(T_BEGIN, T_END) s
                    WHERE r.a = s.b)
        AND NOT EXISTS (SELECT *
                        FROM TEMP_TEST WITH TIME(T_BEGIN, T_END) t
                        WHERE r.b = t.b + 10)
);
</entry>
<entry key="q3.result">
 a | b | t_b | t_e |
--------------------
 2 | 1 | 1   | 2   |
 2 | 1 | 2   | 3   |
 2 | 1 | 3   | 4   |
</entry>

